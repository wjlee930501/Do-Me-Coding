  return "$rc"
}

# M7 worker/delegation-hardening suites (tests/fixtures/m7). Each is a self-contained bash script
# (mktemp sandboxes; the live repo is left byte-identical). GUARDED: a missing script is rc=1 (M8
# precedent — this section can be registered before T012.5 lands the scripts). Returns 0 iff every
