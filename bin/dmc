# M9 release-gate suites (tests/fixtures/m9). Each is a self-contained bash script
# (mktemp sandboxes; the live repo is left byte-identical). GUARDED: a missing script is
# rc=1 (M7/M8 precedent — this section can be registered before T015.1 lands the scripts).
# Returns 0 iff every suite passes.
run_m9_suite() {
  local rc=0 s
  for s in test-release-gate.sh test-e2e-loop.sh; do
    if [ -f "$M9SUITEDIR/$s" ]; then
      bash "$M9SUITEDIR/$s" || rc=1
    else
      echo "dmc selftest m9-suite: missing suite script: $s" >&2; rc=1
    fi
  done
  return "$rc"
}

cmd=${1:-help}
[ $# -gt 0 ] && shift

case "$cmd" in
  orient|landmarks|depsurface|radius)
    exec python3 "$CORE" "$cmd" "$@"
    ;;
  validate)
    sub=${1:-}
    [ $# -gt 0 ] && shift
    case "$sub" in
      plan|run|verification)
        [ $# -ge 1 ] || { echo "usage: dmc validate $sub <path>" >&2; exit 2; }
        exec python3 "$ICORE" "$sub" --validate "$1"
        ;;
      schemas-mirror)
        exec python3 "$ICORE" mirror --check
        ;;
      *)
        echo "dmc validate: unknown target: ${sub:-<none>} \
(plan|run|verification|schemas-mirror)" >&2
        exit 2
        ;;
    esac
    ;;
  legacy)
    sub=${1:-}
    [ $# -gt 0 ] && shift
    case "$sub" in
      ""|list)
        (cd "$HERE/lib" && ls dmc-v0.*.sh 2>/dev/null | sed -E 's/^dmc-(v0\.[0-9.]+-[a-z0-9.-]+)\.sh$/\1/')
        ;;
      *)
        tool="$sub"
        case "$tool" in
          dmc-*.sh) : ;;
          *.sh) tool="dmc-$tool" ;;
          *) tool="dmc-$tool.sh" ;;
        esac
        [ -f "$HERE/lib/$tool" ] || { echo "dmc legacy: unknown tool: $sub (see 'dmc legacy list')" >&2; exit 2; }
        cd "$(cd "$HERE/.." && pwd)"
        exec bash "$HERE/lib/$tool" "$@"
        ;;
    esac
    ;;
  run)
    sub=${1:-}
    [ $# -gt 0 ] && shift
    case "$sub" in
      start)
        # `run start` gains an optional DISPATCH-level `--scope-input FILE` (E1). It is consumed
        # HERE (bash) and NEVER passed into dmc-run-lifecycle.py, which stays byte-untouched: the
        # run core still only mints run.json + snapshot.txt + pointer, and this layer composes the
        # scope.lock compile+validate on top so arming is one fail-closed step. Flag parsing assumes
        # the space-separated `--flag VALUE` form used by every pinned caller (m6/m7/m9 fixtures, the
        # dmc-start-work skill). `--scope-input` is removed before delegation; `--plan`/`--root` are
        # noted for the compose AND left in the delegated argv untouched (default root ".").
        scope_input=""; scope_plan=""; scope_root="."
        delegated=()
        while [ $# -gt 0 ]; do
          case "$1" in
            --scope-input) scope_input=${2:-}; shift 2 || shift ;;
            --plan)  scope_plan=${2:-};    delegated+=("$1" "${2:-}"); shift 2 || shift ;;
            --root)  scope_root=${2:-.};   delegated+=("$1" "${2:-}"); shift 2 || shift ;;
            *)       delegated+=("$1"); shift ;;
          esac
        done
        # Delegate to RCORE as a CAPTURED (non-exec) call so control returns for the compose; the
        # streams flow through UNTOUCHED (no capture, no redirect) so the success stdout AND every
        # RCORE refuse path stay byte-identical to a direct `dmc-run-lifecycle.py start`.
        if [ "${#delegated[@]}" -gt 0 ]; then
          python3 "$RCORE" start "${delegated[@]}"
        else
          python3 "$RCORE" start
        fi
        rc=$?
        # On ANY non-zero RCORE exit (the refuse paths) add NOTHING to either stream (byte-identity).
        [ "$rc" -eq 0 ] || exit "$rc"
        if [ -z "$scope_input" ]; then
          # E2 honest unarmed warning: advisory only, success-path only, exit code unchanged.
          printf 'WARNING: run started UNARMED — no scope.lock; L1 scope enforcement stands down (pass --scope-input FILE to arm)\n' >&2
          exit 0
        fi
        # E1 arm: compile + validate the immutable scope.lock at the run's canonical path. Rooted at
        # <scope_root> so the pointer read / compile --out / validate all resolve the same run.
        run_id=$(head -1 "$scope_root/.harness/runs/current-run-id")
        scope_lock="$scope_root/.harness/runs/$run_id/scope.lock.json"
        if arm_out=$(python3 "$SCOPELOCKLIB" --compile --plan "$scope_plan" \
                       --landmarks "$scope_input" --run-id "$run_id" --root "$scope_root" \
                       --out "$scope_lock" 2>&1) \
           && arm_out=$(python3 "$SCOPELOCKLIB" --validate "$scope_lock" --root "$scope_root" 2>&1); then
          printf 'ARMED: %s (validated)\n' "$scope_lock"
          exit 0
        fi
        # Fail-closed: a run that LOOKS started but has no validated lock is the false-"armed" state
        # this cycle exists to kill. Tear it down deterministically — suspend FIRST (the pointer must
        # still exist for suspend to resolve the run), THEN remove the pointer — and exit 3.
        arm_reason=$(printf '%s\n' "$arm_out" | grep -E -m1 'REFUSED|SCOPE-LOCK|dmc-scope-lock')
        [ -n "$arm_reason" ] || arm_reason="scope-lock compile/validate failed"
        printf 'REFUSED-ARMING: %s\n' "$arm_reason" >&2
        python3 "$RCORE" suspend --root "$scope_root" >/dev/null 2>&1
        rm -f "$scope_root/.harness/runs/current-run-id"
        exit 3
        ;;
      suspend|resume|status|block|blocked-status|unblock)
        exec python3 "$RCORE" "$sub" "$@"
        ;;
      *)
        echo "dmc run: unknown verb: ${sub:-<none>} \
(start|suspend|resume|status|block|blocked-status|unblock)" >&2
        exit 2
        ;;
    esac
    ;;
  bash-radius)
    exec python3 "$BASHRADIUSLIB" "$@"
    ;;
  postbash-diff)
    exec python3 "$POSTBASHLIB" "$@"
    ;;
  verify-crosscheck)
    exec python3 "$CROSSCHECKLIB" "$@"
    ;;
  stop-gate)
    [ "${1:-}" = "quick" ] && shift   # `dmc stop-gate quick ...` == `dmc stop-gate ...`
    exec python3 "$STOPGATELIB" "$@"
    ;;
  agents-md)
    exec python3 "$AGENTSMDLIB" "$@"
    ;;
  skills-mirror)
    exec python3 "$SKILLSMIRRORLIB" "$@"
    ;;
  doctor)
    exec python3 "$DOCTORLIB" "$@"
    ;;
  roles)
    exec python3 "$ROLESLIB" "$@"
    ;;
  verdict)
    sub=${1:-}
    [ $# -gt 0 ] && shift
    case "$sub" in
      validate)
        [ $# -ge 1 ] || { echo "usage: dmc verdict validate <path>" >&2; exit 2; }
        exec python3 "$VERDICTLIB" validate "$@"
        ;;
      gate)
        exec python3 "$GATELIB" gate "$@"
        ;;
      *)
        echo "dmc verdict: unknown verb: ${sub:-<none>} (validate|gate)" >&2
        exit 2
        ;;
    esac
    ;;
  worker)
    sub=${1:-}
    [ $# -gt 0 ] && shift
    case "$sub" in
      review-check|authorize|apply-check|fidelity)
        exec python3 "$WORKERREVLIB" "$sub" "$@"
        ;;
      *)
        echo "dmc worker: unknown verb: ${sub:-<none>} \
(review-check|authorize|apply-check|fidelity)" >&2
        exit 2
        ;;
    esac
    ;;
  gate)
    sub=${1:-}
    [ $# -gt 0 ] && shift
    case "$sub" in
      release)
        exec python3 "$RGATELIB" release "$@"
        ;;
      *)
        echo "dmc gate: unknown verb: ${sub:-<none>} (release)" >&2
        exit 2
        ;;
    esac
    ;;
  delegation)
    exec python3 "$DELEGLIB" "$@"
    ;;
  linkcheck)
    exec python3 "$LINKLIB" "$@"
    ;;
  metrics)
    sub=${1:-}
    [ $# -gt 0 ] && shift
    case "$sub" in
      record|rollup|self-test|selftest)
        exec python3 "$METRICSLIB" "$sub" "$@"
        ;;
      *)
        echo "dmc metrics: unknown verb: ${sub:-<none>} (record|rollup|self-test)" >&2
        exit 2
        ;;
    esac
    ;;
  effort)
    exec bash "$EFFORTLIB" "$@"
    ;;
  course)
    exec bash "$COURSELIB" "$@"
    ;;
  mirror-check)
    exec python3 "$LCORE" mirror --check
    ;;
  rollback-test)
    exec python3 "$LCORE" rollback-test
    ;;
  selftest)
    if [ "${1:-}" = "--all" ]; then
      rc=0
      for t in orient landmarks depsurface radius \
        validate-plan validate-run validate-verification schemas-mirror legacy-mirror; do
        case "$t" in
          orient|landmarks|depsurface|radius)
            python3 "$CORE" "$t" --self-test || rc=1 ;;
          validate-plan)          python3 "$ICORE" plan --self-test || rc=1 ;;
          validate-run)           python3 "$ICORE" run --self-test || rc=1 ;;
          validate-verification)  python3 "$ICORE" verification --self-test || rc=1 ;;
          schemas-mirror)         python3 "$ICORE" mirror --self-test || rc=1 ;;
          legacy-mirror)          python3 "$LCORE" mirror --self-test || rc=1 ;;
        esac
      done
      python3 "$LCORE" selftest-all || rc=1
      python3 "$RUNCORE" run-core || rc=1
      python3 "$RUNCORE" loop-core || rc=1
      python3 "$ROLESLIB" --self-test || rc=1
      python3 "$VERDICTLIB" --self-test || rc=1
      python3 "$GATELIB" --self-test || rc=1
      python3 "$DELEGLIB" --self-test || rc=1
      python3 "$LINKLIB" --self-test || rc=1
      python3 "$BASHRADIUSLIB" --self-test || rc=1
      python3 "$POSTBASHLIB" --self-test || rc=1
      python3 "$CROSSCHECKLIB" --self-test || rc=1
      python3 "$STOPGATELIB" --self-test || rc=1
      run_m6_suite || rc=1
      python3 "$SKILLSMIRRORLIB" --self-test || rc=1
      python3 "$AGENTSMDLIB" --self-test || rc=1
      run_m65_suite || rc=1
      python3 "$DOCTORLIB" --self-test || rc=1
      run_m8_suite || rc=1
      python3 "$WORKERREVLIB" --self-test || rc=1
      run_m7_suite || rc=1
      python3 "$RGATELIB" --self-test || rc=1
      run_m9_suite || rc=1
      python3 "$METRICSLIB" --self-test || rc=1
      exit "$rc"
    fi
    [ $# -eq 0 ] && set -- orient landmarks depsurface radius \
      validate-plan validate-run validate-verification schemas-mirror legacy-mirror metrics
    rc=0
    for t in "$@"; do
      case "$t" in
        orient|landmarks|depsurface|radius)
          python3 "$CORE" "$t" --self-test || rc=1 ;;
        validate-plan)          python3 "$ICORE" plan --self-test || rc=1 ;;
        validate-run)           python3 "$ICORE" run --self-test || rc=1 ;;
        validate-verification)  python3 "$ICORE" verification --self-test || rc=1 ;;
        schemas-mirror)         python3 "$ICORE" mirror --self-test || rc=1 ;;
        legacy-mirror)          python3 "$LCORE" mirror --self-test || rc=1 ;;
        run-core)               python3 "$RUNCORE" run-core || rc=1 ;;
        loop-core)              python3 "$RUNCORE" loop-core || rc=1 ;;
        roles)                  python3 "$ROLESLIB" --self-test || rc=1 ;;
        verdict)                python3 "$VERDICTLIB" --self-test || rc=1
                                python3 "$GATELIB" --self-test || rc=1 ;;
        delegation)             python3 "$DELEGLIB" --self-test || rc=1 ;;
        linkcheck)              python3 "$LINKLIB" --self-test || rc=1 ;;
        m6-core)                python3 "$BASHRADIUSLIB" --self-test || rc=1
                                python3 "$POSTBASHLIB" --self-test || rc=1
                                python3 "$CROSSCHECKLIB" --self-test || rc=1
                                python3 "$STOPGATELIB" --self-test || rc=1 ;;
        m6-suite)               run_m6_suite || rc=1 ;;
        skills-mirror)          python3 "$SKILLSMIRRORLIB" --self-test || rc=1 ;;
        agents-md)              python3 "$AGENTSMDLIB" --self-test || rc=1 ;;
        m65-suite)              run_m65_suite || rc=1 ;;
        doctor)                 python3 "$DOCTORLIB" --self-test || rc=1 ;;
        m8-suite)               run_m8_suite || rc=1 ;;
        worker-check)           python3 "$WORKERREVLIB" --self-test || rc=1 ;;
        m7-suite)               run_m7_suite || rc=1 ;;
        release-gate)           python3 "$RGATELIB" --self-test || rc=1 ;;
        m9-suite)               run_m9_suite || rc=1 ;;
        metrics)                python3 "$METRICSLIB" --self-test || rc=1 ;;
        *) echo "dmc selftest: unknown target: $t" >&2; exit 2 ;;
      esac
    done
    exit "$rc"
    ;;
  help|-h|--help)
    usage
    ;;
  *)
    echo "dmc: unknown command: $cmd" >&2
    usage >&2
    exit 2
    ;;
esac
