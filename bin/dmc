#!/usr/bin/env bash
# dmc — DMC v1.0 Ring-0 entry point (M2 surface: repository intelligence P1/P2/P4/P5).
# Additive, advisory, offline: no network, no live provider call, no secret read (path-only
# exclusion in the core). The runtime enforcement floor stays the hooks.
set -u

HERE=$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)
CORE="$HERE/lib/dmc-repo-intel.py"
ICORE="$HERE/lib/dmc-instance-validate.py"
LCORE="$HERE/lib/dmc-legacy-selftest.py"
RCORE="$HERE/lib/dmc-run-lifecycle.py"
RUNCORE="$HERE/lib/dmc-run-core-selftest.py"
ROLESLIB="$HERE/lib/dmc-roles.py"
VERDICTLIB="$HERE/lib/dmc-critic-verdict.py"
GATELIB="$HERE/lib/dmc-verdict-gate.py"
DELEGLIB="$HERE/lib/dmc-delegation.py"
LINKLIB="$HERE/lib/dmc-orchestration-linkcheck.py"
BASHRADIUSLIB="$HERE/lib/dmc-bash-radius.py"
POSTBASHLIB="$HERE/lib/dmc-postbash-diff.py"
CROSSCHECKLIB="$HERE/lib/dmc-verify-crosscheck.py"
STOPGATELIB="$HERE/lib/dmc-stop-gate.py"
AGENTSMDLIB="$HERE/lib/dmc-agents-md.py"
SKILLSMIRRORLIB="$HERE/lib/dmc-skills-mirror.py"
DOCTORLIB="$HERE/lib/dmc-doctor.py"
M6SUITEDIR="$HERE/../tests/fixtures/m6"
M65SUITEDIR="$HERE/../tests/fixtures/m6.5"
M8SUITEDIR="$HERE/../tests/fixtures/m8"

usage() {
  cat <<'EOF'
usage: dmc <command> [args]

commands (M2):
  orient      [--root DIR] [--out FILE] | --validate FILE [--root DIR] | --self-test
  landmarks   [--root DIR] [--out FILE] | --validate FILE | --self-test
  depsurface  [--root DIR] [--out FILE] | --validate FILE | --self-test
  radius      --depsurface F --landmarks F --checks F --scope P [P...]
              [--out FILE] | --validate FILE | --self-test

commands (M4):
  run         start --plan FILE [--root DIR] [--work-id ID]   mint + arm a run (refuses unless
                                              the plan is APPROVED; refuses a second start while a
                                              run is active; M6: refuses a plan-bound critic REJECT +
                                              writes snapshot.txt) -> .harness/runs/<run-id>/run.json
  run         suspend|resume|status [--root DIR] [--run-id ID]   drive/report the run state machine
                                              (INIT->RUNNING->SUSPENDED->RESUMING->RUNNING->DONE)

commands (M6 hook-hardening — Ring-0 verdict CLIs the Ring-1 shims call):
  bash-radius [--cmd STR | JSON stdin] [--scope-lock FILE]   classify a Bash command's write radius
                                              (L0 deny git apply/patch always; L1 scope-lock
                                              adjudication when armed) -> 0 allow / 3 ask / 4 deny
  postbash-diff --scope-lock FILE --snapshot FILE [--root DIR]   post-Bash out-of-scope change
                                              detector vs the arming snapshot -> 0 clean / 4 blocked
  verify-crosscheck --report FILE --run DIR   semantic verification-report cross-check (run-id bind,
                                              changed-files in scope, honest PASS) -> 0 ACCEPT / 3 REFUSE
  stop-gate   quick [--run DIR | --root DIR | --run-id ID] [--report FILE]   completion quick gate:
                                              receipt coverage + BLOCKED + cross-check -> 0 pass / 4 hold
  run         block --reason R [--paths P...] [--created-by CHECK] | blocked-status | unblock
              --resolution TEXT [--root DIR] [--run-id ID]   BLOCKED sidecar marker (blocked.json);
                                              written/read/cleared only here (run state machine untouched)

commands (M5 orchestration):
  roles       validate <path> | lookup <role> [--registry PATH]   role-registry validator + lookup
                                              (orchestration/roles.json, P14 registry)
  verdict     validate <path>                critic-verdict.json validator (P16)
  verdict     gate --verdict FILE --plan-hash HEX   Ring-0 start-work precondition (REFUSE when the
                                              referenced critic-verdict is absent/invalid/plan_hash-
                                              mismatched; opens nothing, C11)
  delegation  validate <path> [--registry P] delegation-record schema validator (role resolves in
                                              roles.json; runtime records pipeline is M7)
  linkcheck   [--root DIR]                    no skill/agent/doc-banner references a nonexistent
                                              dmc-verb / artifact-path / role (exit 0 clean / 3 dangling)

commands (M6.5 Codex adapter):
  agents-md   [--root DIR] [--out FILE | --stdout] | --validate FILE   host AGENTS.md generator
                                              (docs/CODEX_ADAPTER.md §5 content contract; every
                                              non-derivable fact emitted literally as `Unknown`;
                                              NEVER overwrites an existing AGENTS.md; warns when
                                              output exceeds the 32 KiB Codex size budget, never
                                              truncates) + `--validate` (0 VALID / 3 REFUSED).
                                              This verb IS the /dmc-init-deep generator.
  skills-mirror [--self-test]                 .agents/skills <-> .claude/skills mirror/drift check
                                              (default: one-shot report; --self-test: hermetic
                                              negative controls) -> 0 clean / 1 drift

commands (M8 host install):
  doctor      [--root DIR]                    host self-check (fast, offline): interpreters; Ring-0
                                              presence; Claude hook registration + a synthetic-event
                                              FIRING PROBE (canned PreToolUse -> Ring-0 verdict CLI
                                              deny/allow envelope) => firing PROVEN; Codex config/
                                              trust presence + turn-free surfaces => ADVISORY (never
                                              an enforced-class claim on a Codex line); foreign-
                                              harness non-interference; the harness-matrix.json
                                              enforcement matrix rendered PER-HOST + the DMC mode
                                              host-independently. 0 healthy / 1 real defect.

commands (M3):
  validate    plan|run|verification <path>   instance validator (ACCEPT => 0, REFUSED => 3)
  validate    schemas-mirror                 mirrors == canonical roots modulo generated header

  legacy      list                           list the copy-routed v0.x tools (bin/lib)
  legacy      <tool-id> [args...]            route to a copied v0.x tool, e.g.
                                              `dmc legacy v0.6.0-verify --self-test`
  mirror-check                               bin/lib <-> .harness/evidence byte-equality (55 files)
  rollback-test                              verify 'rm -rf bin/' loses no functionality
                                              (simulated in a disposable temp copy only)

  selftest    [orient|landmarks|depsurface|radius|validate-plan|validate-run|
               validate-verification|schemas-mirror|legacy-mirror ...]   (default: all sections)
  selftest    run-core|loop-core             M4 run-core/loop-core module self-tests + the
                                              hermetic run round-trip (named-only; also under
                                              --all; NOT in the no-arg default)
  selftest    roles|verdict|delegation|linkcheck   M5 orchestration validator self-tests (roles
                                              registry; critic-verdict validator + verdict-gate;
                                              delegation validator; orchestration link-check +
                                              arm-run-id pre-run). Named-only; also under --all;
                                              NOT in the no-arg default.
  selftest    m6-core                        M6 Ring-0 verdict-CLI self-tests (bash-radius,
                                              postbash-diff, verify-crosscheck, stop-gate).
                                              Named-only; also under --all; NOT in the no-arg default.
  selftest    m6-suite                       M6 hook-hardening suites (tests/fixtures/m6):
                                              adversarial negative controls, compatibility matrix,
                                              ultrawork stop-block E2E, pre-commit restore proof.
                                              Named-only; also under --all; NOT in the no-arg default.
  selftest    agents-md|skills-mirror         M6.5 Codex-adapter module self-tests: host AGENTS.md
                                              generator + validator (agents-md); .agents/.claude
                                              skills mirror/drift check (skills-mirror). Named-only;
                                              also under --all; NOT in the no-arg default.
  selftest    m65-suite                       M6.5 Codex-adapter suites (tests/fixtures/m6.5):
                                              codex shims, skills mirror, host AGENTS.md generator.
                                              Named-only; also under --all; NOT in the no-arg default.
  selftest    doctor                          M8 host self-check module self-test (dmc-doctor.py):
                                              firing-probe positive control + Codex-scoped honesty
                                              grep + negative controls (missing-python3, seeded
                                              Codex-enforced line, wiring gap, foreign harness).
                                              Named-only; also under --all; NOT in the no-arg default.
  selftest    m8-suite                        M8 host-install suites (tests/fixtures/m8): install
                                              round-trip, idempotency, doctor negative controls,
                                              manifest drift. Named-only; also under --all; NOT in
                                              the no-arg default.
  selftest    --all                          above + all 49 legacy tools (bin/lib) vs the
                                              pinned baseline + rollback-test + run-core/loop-core
                                              + the four M5 orchestration sections + m6-core + m6-suite
                                              + skills-mirror + agents-md + m65-suite + doctor
                                              + m8-suite (slow: ~10+ min)
  help

Artifacts conform to .harness/schemas/{orientation,landmarks,depsurface,radius}.schema.md.
Instance validators check plan/run/verification docs against PLAN_SCHEMA.md / RUN_SCHEMA.md /
VERIFICATION_SCHEMA.md (canonical roots; mirrored under .harness/schemas/).
Legacy v0.x tools are copy-routed (never moved) from .harness/evidence/dmc-v0.*.{sh,py} into
bin/lib/; the originals stay canonical (per .harness/evidence/dmc-v1-m3-baseline.md).
Validators are fail-closed: VALID => exit 0, REFUSED => exit 3.
EOF
}

# M6 hook-hardening suites (tests/fixtures/m6). Each is a self-contained bash
# script (mktemp sandboxes; the live repo is left byte-identical). Returns 0 iff
# every suite passes.
run_m6_suite() {
  local rc=0 s
  for s in test-adversarial.sh test-compat.sh test-e2e-ultrawork.sh test-restore.sh; do
    if [ -f "$M6SUITEDIR/$s" ]; then
      bash "$M6SUITEDIR/$s" || rc=1
    else
      echo "dmc selftest m6-suite: missing suite script: $s" >&2; rc=1
    fi
  done
  return "$rc"
}

# M6.5 Codex-adapter suites (tests/fixtures/m6.5). Each is a self-contained bash
# script (mktemp sandboxes; the live repo is left byte-identical). Returns 0 iff
# every suite passes.
run_m65_suite() {
  local rc=0 s
  for s in test-codex-shims.sh test-skills-mirror.sh test-agents-md.sh; do
    if [ -f "$M65SUITEDIR/$s" ]; then
      bash "$M65SUITEDIR/$s" || rc=1
    else
      echo "dmc selftest m65-suite: missing suite script: $s" >&2; rc=1
    fi
  done
  return "$rc"
}

# M8 host-install suites (tests/fixtures/m8). Each is a self-contained bash script
# (mktemp sandboxes; the live repo is left byte-identical). GUARDED: a missing script
# is rc=1, so this section can be registered before T013.4 lands the scripts (M6.5
# precedent). Returns 0 iff every suite passes.
run_m8_suite() {
  local rc=0 s
  for s in test-install-roundtrip.sh test-idempotency.sh test-doctor-negcontrols.sh test-manifest-drift.sh; do
    if [ -f "$M8SUITEDIR/$s" ]; then
      bash "$M8SUITEDIR/$s" || rc=1
    else
      echo "dmc selftest m8-suite: missing suite script: $s" >&2; rc=1
    fi
  done
  return "$rc"
}

cmd=${1:-help}
[ $# -gt 0 ] && shift

case "$cmd" in
  orient|landmarks|depsurface|radius)
    exec python3 "$CORE" "$cmd" "$@"
    ;;
  validate)
    sub=${1:-}
    [ $# -gt 0 ] && shift
    case "$sub" in
      plan|run|verification)
        [ $# -ge 1 ] || { echo "usage: dmc validate $sub <path>" >&2; exit 2; }
        exec python3 "$ICORE" "$sub" --validate "$1"
        ;;
      schemas-mirror)
        exec python3 "$ICORE" mirror --check
        ;;
      *)
        echo "dmc validate: unknown target: ${sub:-<none>} \
(plan|run|verification|schemas-mirror)" >&2
        exit 2
        ;;
    esac
    ;;
  legacy)
    sub=${1:-}
    [ $# -gt 0 ] && shift
    case "$sub" in
      ""|list)
        (cd "$HERE/lib" && ls dmc-v0.*.sh 2>/dev/null | sed -E 's/^dmc-(v0\.[0-9.]+-[a-z0-9.-]+)\.sh$/\1/')
        ;;
      *)
        tool="$sub"
        case "$tool" in
          dmc-*.sh) : ;;
          *.sh) tool="dmc-$tool" ;;
          *) tool="dmc-$tool.sh" ;;
        esac
        [ -f "$HERE/lib/$tool" ] || { echo "dmc legacy: unknown tool: $sub (see 'dmc legacy list')" >&2; exit 2; }
        exec bash "$HERE/lib/$tool" "$@"
        ;;
    esac
    ;;
  run)
    sub=${1:-}
    [ $# -gt 0 ] && shift
    case "$sub" in
      start|suspend|resume|status|block|blocked-status|unblock)
        exec python3 "$RCORE" "$sub" "$@"
        ;;
      *)
        echo "dmc run: unknown verb: ${sub:-<none>} \
(start|suspend|resume|status|block|blocked-status|unblock)" >&2
        exit 2
        ;;
    esac
    ;;
  bash-radius)
    exec python3 "$BASHRADIUSLIB" "$@"
    ;;
  postbash-diff)
    exec python3 "$POSTBASHLIB" "$@"
    ;;
  verify-crosscheck)
    exec python3 "$CROSSCHECKLIB" "$@"
    ;;
  stop-gate)
    [ "${1:-}" = "quick" ] && shift   # `dmc stop-gate quick ...` == `dmc stop-gate ...`
    exec python3 "$STOPGATELIB" "$@"
    ;;
  agents-md)
    exec python3 "$AGENTSMDLIB" "$@"
    ;;
  skills-mirror)
    exec python3 "$SKILLSMIRRORLIB" "$@"
    ;;
  doctor)
    exec python3 "$DOCTORLIB" "$@"
    ;;
  roles)
    exec python3 "$ROLESLIB" "$@"
    ;;
  verdict)
    sub=${1:-}
    [ $# -gt 0 ] && shift
    case "$sub" in
      validate)
        [ $# -ge 1 ] || { echo "usage: dmc verdict validate <path>" >&2; exit 2; }
        exec python3 "$VERDICTLIB" validate "$@"
        ;;
      gate)
        exec python3 "$GATELIB" gate "$@"
        ;;
      *)
        echo "dmc verdict: unknown verb: ${sub:-<none>} (validate|gate)" >&2
        exit 2
        ;;
    esac
    ;;
  delegation)
    exec python3 "$DELEGLIB" "$@"
    ;;
  linkcheck)
    exec python3 "$LINKLIB" "$@"
    ;;
  mirror-check)
    exec python3 "$LCORE" mirror --check
    ;;
  rollback-test)
    exec python3 "$LCORE" rollback-test
    ;;
  selftest)
    if [ "${1:-}" = "--all" ]; then
      rc=0
      for t in orient landmarks depsurface radius \
        validate-plan validate-run validate-verification schemas-mirror legacy-mirror; do
        case "$t" in
          orient|landmarks|depsurface|radius)
            python3 "$CORE" "$t" --self-test || rc=1 ;;
          validate-plan)          python3 "$ICORE" plan --self-test || rc=1 ;;
          validate-run)           python3 "$ICORE" run --self-test || rc=1 ;;
          validate-verification)  python3 "$ICORE" verification --self-test || rc=1 ;;
          schemas-mirror)         python3 "$ICORE" mirror --self-test || rc=1 ;;
          legacy-mirror)          python3 "$LCORE" mirror --self-test || rc=1 ;;
        esac
      done
      python3 "$LCORE" selftest-all || rc=1
      python3 "$RUNCORE" run-core || rc=1
      python3 "$RUNCORE" loop-core || rc=1
      python3 "$ROLESLIB" --self-test || rc=1
      python3 "$VERDICTLIB" --self-test || rc=1
      python3 "$GATELIB" --self-test || rc=1
      python3 "$DELEGLIB" --self-test || rc=1
      python3 "$LINKLIB" --self-test || rc=1
      python3 "$BASHRADIUSLIB" --self-test || rc=1
      python3 "$POSTBASHLIB" --self-test || rc=1
      python3 "$CROSSCHECKLIB" --self-test || rc=1
      python3 "$STOPGATELIB" --self-test || rc=1
      run_m6_suite || rc=1
      python3 "$SKILLSMIRRORLIB" --self-test || rc=1
      python3 "$AGENTSMDLIB" --self-test || rc=1
      run_m65_suite || rc=1
      python3 "$DOCTORLIB" --self-test || rc=1
      run_m8_suite || rc=1
      exit "$rc"
    fi
    [ $# -eq 0 ] && set -- orient landmarks depsurface radius \
      validate-plan validate-run validate-verification schemas-mirror legacy-mirror
    rc=0
    for t in "$@"; do
      case "$t" in
        orient|landmarks|depsurface|radius)
          python3 "$CORE" "$t" --self-test || rc=1 ;;
        validate-plan)          python3 "$ICORE" plan --self-test || rc=1 ;;
        validate-run)           python3 "$ICORE" run --self-test || rc=1 ;;
        validate-verification)  python3 "$ICORE" verification --self-test || rc=1 ;;
        schemas-mirror)         python3 "$ICORE" mirror --self-test || rc=1 ;;
        legacy-mirror)          python3 "$LCORE" mirror --self-test || rc=1 ;;
        run-core)               python3 "$RUNCORE" run-core || rc=1 ;;
        loop-core)              python3 "$RUNCORE" loop-core || rc=1 ;;
        roles)                  python3 "$ROLESLIB" --self-test || rc=1 ;;
        verdict)                python3 "$VERDICTLIB" --self-test || rc=1
                                python3 "$GATELIB" --self-test || rc=1 ;;
        delegation)             python3 "$DELEGLIB" --self-test || rc=1 ;;
        linkcheck)              python3 "$LINKLIB" --self-test || rc=1 ;;
        m6-core)                python3 "$BASHRADIUSLIB" --self-test || rc=1
                                python3 "$POSTBASHLIB" --self-test || rc=1
                                python3 "$CROSSCHECKLIB" --self-test || rc=1
                                python3 "$STOPGATELIB" --self-test || rc=1 ;;
        m6-suite)               run_m6_suite || rc=1 ;;
        skills-mirror)          python3 "$SKILLSMIRRORLIB" --self-test || rc=1 ;;
        agents-md)              python3 "$AGENTSMDLIB" --self-test || rc=1 ;;
        m65-suite)              run_m65_suite || rc=1 ;;
        doctor)                 python3 "$DOCTORLIB" --self-test || rc=1 ;;
        m8-suite)               run_m8_suite || rc=1 ;;
        *) echo "dmc selftest: unknown target: $t" >&2; exit 2 ;;
      esac
    done
    exit "$rc"
    ;;
  help|-h|--help)
    usage
    ;;
  *)
    echo "dmc: unknown command: $cmd" >&2
    usage >&2
    exit 2
    ;;
esac
