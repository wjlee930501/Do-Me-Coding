#!/usr/bin/env bash
#
# dmc-glm-smoke — safe local GLM v0.2.1 live smoke runner for Do-Me-Coding.
#
# Runs EXACTLY ONE toy-only GLM live smoke through the existing glm-api adapter,
# then validates the returned worker result with worker-result-check.py and
# reports only sanitized fields.
#
# SAFETY CONTRACT (non-negotiable):
#   - GLM_API_KEY is read from the macOS Keychain (service DMC_GLM_API_KEY) ONLY.
#   - The key is NEVER printed, echoed, logged, serialized, or written to disk.
#   - The key is exported solely for the smoke child process and unset on exit (trap).
#   - Toy task ONLY: no real repo context, no source code, no .env*, no secrets,
#     no customer / company / patient data. (The adapter additionally fail-closes
#     via worker-context-guard before any payload is built.)
#   - Fail-closed on Keychain miss or empty key. No mutation, no git apply,
#     no auto-apply of the proposal, no commit, no push.
#
# Usage:  ./dmc-glm-smoke
#
set -euo pipefail            # NOTE: never `set -x` — that could expose the key.

SERVICE="DMC_GLM_API_KEY"
ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
ADAPTER="$ROOT/.claude/workers/providers/glm-api/glm-api-adapter.py"
TASK="$ROOT/.harness/workers/providers/glm-api/smoke-task.json"
VALIDATOR="$ROOT/.claude/hooks/worker-result-check.py"

# Result lands in a private temp dir (NOT the repo) so git stays clean.
WORKDIR="$(mktemp -d "${TMPDIR:-/tmp}/dmc-glm-smoke.XXXXXX")"
RESULT="$WORKDIR/result.json"

# --- trap: always unset the key and remove the temp dir, on any exit path ------
cleanup() {
  unset GLM_API_KEY 2>/dev/null || true
  rm -rf "$WORKDIR" 2>/dev/null || true
}
trap cleanup EXIT INT TERM

fail() { echo "dmc-glm-smoke: FAIL — $1" >&2; exit 1; }

# --- preconditions -------------------------------------------------------------
[ -f "$ADAPTER" ]   || fail "adapter not found: $ADAPTER"
[ -f "$TASK" ]      || fail "toy smoke task not found: $TASK"
[ -f "$VALIDATOR" ] || fail "validator not found: $VALIDATOR"
command -v python3   >/dev/null 2>&1 || fail "python3 not on PATH"
command -v security  >/dev/null 2>&1 || fail "macOS 'security' tool not on PATH"

# --- git must be clean BEFORE the run -----------------------------------------
if [ -n "$(git -C "$ROOT" status --porcelain 2>/dev/null)" ]; then
  fail "git working tree is not clean before run; refusing (commit/stash first)"
fi
echo "dmc-glm-smoke: git clean (pre-run) OK"

# --- read key from Keychain (fail-closed); value is never printed --------------
# Capture into a local var via command substitution; no echo, no logging.
if ! _key="$(security find-generic-password -s "$SERVICE" -w 2>/dev/null)"; then
  fail "Keychain lookup failed for service '$SERVICE' (not found / locked)"
fi
if [ -z "${_key:-}" ]; then
  fail "GLM_API_KEY from Keychain is empty; refusing (fail-closed)"
fi
export GLM_API_KEY="$_key"
unset _key
echo "dmc-glm-smoke: key loaded from Keychain service '$SERVICE' (value redacted)"

# --- run EXACTLY ONE toy-only live smoke --------------------------------------
echo "dmc-glm-smoke: running ONE toy live smoke (task: $(basename "$TASK"))..."
if ! python3 "$ADAPTER" \
      --task "$TASK" \
      --live --allow-network \
      --out "$RESULT" >/dev/null; then
  fail "adapter live call failed (see adapter stderr above; no proposal applied)"
fi

# Defense-in-depth: the key must not have leaked into the written result.
if grep -q "$SERVICE" "$RESULT" 2>/dev/null; then
  fail "unexpected: service name present in result; aborting before report"
fi

# --- validate the returned result ---------------------------------------------
echo "dmc-glm-smoke: validating result with worker-result-check.py..."
if python3 "$VALIDATOR" "$TASK" "$RESULT"; then
  VERDICT="ACCEPT"
else
  VERDICT="REJECT"
fi

# --- sanitized report (no key, no raw patch) ----------------------------------
echo
echo "==== SANITIZED SMOKE REPORT ===="
python3 - "$RESULT" <<'PY'
import json, sys
r = json.load(open(sys.argv[1]))
pm = r.get("provider_metadata") or {}
print(f"  task_id            : {r.get('task_id')}")
print(f"  confidence         : {r.get('confidence')}")
print(f"  no_direct_mutation : {r.get('no_direct_mutation')}")
print(f"  files_changed (#)  : {len(r.get('files_changed') or [])}")
print(f"  has_proposed_patch : {bool((r.get('proposed_patch') or '').strip())}")
print(f"  provider           : {pm.get('provider')}")
print(f"  model_claimed      : {pm.get('model_claimed')}")
print(f"  invocation_id      : {pm.get('invocation_id')}")
print(f"  credential_exposure: {pm.get('credential_exposure')}")
summary = (r.get("summary") or "").strip().replace("\n", " ")
if len(summary) > 280:
    summary = summary[:280] + "…"
print(f"  summary            : {summary}")
PY
echo "  validator_verdict  : $VERDICT"
echo "================================"

# --- git must be clean AFTER the run ------------------------------------------
if [ -n "$(git -C "$ROOT" status --porcelain 2>/dev/null)" ]; then
  fail "git working tree changed during run; investigate (nothing should mutate the repo)"
fi
echo "dmc-glm-smoke: git clean (post-run) OK"

[ "$VERDICT" = "ACCEPT" ] || fail "result REJECTED by validator"
echo "dmc-glm-smoke: DONE — one toy live smoke, validator ACCEPT, repo unchanged."
